[env]
SHELL = "/bin/zsh"

[terminal]
shell = { program = "/bin/zsh", args = ["-l"] }

[window]
padding = { x = 10, y = 10 }
opacity = 0.8

[font]
normal = { family = "DepartureMono Nerd Font", style = "Regular" }

[colors]
primary = { background = "#222831", foreground = "#ffd369" }

[[hints.enabled]]
hyperlinks = true
regex = "(ipfs:|ipns:|magnet:|mailto:|gemini://|gopher://|https://|http://|news:|file:|git://|ssh:|ftp://)[^\\u0000-\\u001F\\u007F-\\u009F<>\"\\s{-}\\^⟨⟩`]+"
command = "xdg-open"

[hints.enabled.mouse]
enabled = true
